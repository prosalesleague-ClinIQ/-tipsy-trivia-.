# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=./data/tipsy-trivia.db

# Admin Panel
ADMIN_PASSWORD=changeme-in-production

# Optional: Postgres (leave blank to use SQLite)
# POSTGRES_URL=postgres://user:pass@localhost:5432/tipsy_trivia

# CORS - comma separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ElevenLabs TTS (optional — browser fallback used if absent)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Ad Provider (dev | google_ima)
AD_PROVIDER=dev

# Optional: Google IMA Ad Unit ID
# AD_UNIT_ID=your-ad-unit-id-here

# Session Secret
SESSION_SECRET=change-me-in-production-to-random-string

# Client Configuration (Vite)
VITE_SERVER_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
